{
  "compilerOptions": {
    "types": ["./types"],
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "types.d.ts",
    "src/electron/**/*.ts",
    "src/electron/**/*.cts",
    "src/electron/**/*.mts"
  ]
}
